# ========================
# BACKEND (backend/.env)
# ========================

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/muniprioritise

# JWT secret — use a long random string, keep it private
JWT_SECRET=replace-this-with-a-long-random-string
JWT_EXPIRES_IN=7d

# URL where the Python algorithm microservice is running
ALGORITHM_SERVICE_URL=http://localhost:8000

# Cloudinary — for photo uploads (get free credentials at cloudinary.com)
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name

# Port the backend runs on
PORT=3000


# ========================
# ALGORITHM SERVICE (algorithm/.env)
# ========================

PORT=8000


# ========================
# MOBILE APP (mobile/app.config.js)
# ========================
# Set this in app.config.js, not a .env file
# API_BASE_URL=http://localhost:3000/api/v1


# ========================
# DASHBOARD (dashboard/.env)
# ========================

VITE_API_BASE_URL=http://localhost:3000/api/v1


# ========================
# NOTES
# ========================
# - Copy this file to .env in each sub-project folder and fill in your values
# - NEVER commit your actual .env file — it is in .gitignore
# - Ask in the group chat if you're unsure what value to use for a variable
